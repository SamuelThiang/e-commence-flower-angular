PORT=3000
NODE_ENV=development

# Neon / hosted Postgres: paste the connection string from the Neon dashboard (recommended).
# When set, DATABASE_HOST / DATABASE_PORT / DATABASE_NAME / DATABASE_USER / DATABASE_PASSWORD are ignored.
# DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Local Postgres (leave DATABASE_URL unset):
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ecommerce_florist_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_postgres_password_here

# Optional: TLS for local discrete-vars mode only (Neon uses TLS automatically via DATABASE_URL).
# DATABASE_SSL=true

JWT_SECRET=replace-with-a-long-random-secret-for-production

# Google Sign-In (OAuth 2.0 Web client ID from Google Cloud Console — must match Angular environment.googleClientId)
# GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

FRONTEND_ORIGIN=http://localhost:4200

# Optional: shared secret for uploads — send header X-Admin-Upload-Key: <same value>.
# If unset, uploads require Bearer JWT for a user with role admin (see README).
# ADMIN_UPLOAD_KEY=long-random-secret
